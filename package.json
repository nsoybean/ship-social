    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "npm run test:store",
    "test:store": "tsx --test tests/*.test.mjs"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.0",
    "@lottiefiles/dotlottie-react": "^0.18.3",
    "@phosphor-icons/react": "^2.1.10",
    "ai": "^6.0.108",
    "embedded-postgres": "^18.3.0-beta.16",
    "next": "15.2.0",
    "pg": "^8.20.0",
    "popover": "^2.4.1",
    "react": "19.0.0",
    "react-colorful": "^5.6.1",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.94.0",
    "@types/node": "^24.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
