{
  "name": "ship-social",
  "version": "0.1.8",
  "private": false,
  "description": "Ship -> Social, Next.js app with GitHub connect and repo selection",
  "repository": {
    "type": "git",
    "url": "https://github.com/nsoybean/ship-social"
  },
  "homepage": "https://github.com/nsoybean/ship-social#readme",
  "bugs": {
    "url": "https://github.com/nsoybean/ship-social/issues"
  },
  "files": [
    ".env.example",
    "README.md",
    "app",
    "bin",
    "components",
    "jsconfig.json",
    "lib",
    "migrations",
    "next-env.d.ts",
    "public",
    "scripts",
    "tsconfig.json"
  ],
  "bin": {
    "ship-social": "bin/ship-social.js"
  },
  "scripts": {
    "quickstart": "node ./bin/ship-social.js quickstart",
    "db:migrate": "tsx ./scripts/db-migrate.mjs",
